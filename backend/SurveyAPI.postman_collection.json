            "url": { "raw": "{{baseUrl}}/api/surveys", "host": ["{{baseUrl}}"], "path": ["api", "surveys"] },
            "body": {
              "mode": "raw",
              "raw": "<survey><name>Graduate Developer Application Survey</name><description>Initial candidate screening survey</description></survey>"
            }
          },
          "response": [
            {
              "name": "Created",
              "status": "Created",
              "code": 201,
              "body": "<survey id=\"1\"><name>Graduate Developer Application Survey</name><description>Initial candidate screening survey</description></survey>"
            }
          ]
        },
        {
          "name": "List Surveys",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/xml" }],
            "url": { "raw": "{{baseUrl}}/api/surveys", "host": ["{{baseUrl}}"], "path": ["api", "surveys"] }
